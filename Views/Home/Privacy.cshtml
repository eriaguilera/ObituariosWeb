@model System.Data.DataTable

<h2>Datos almacenados en el sistema</h2>

<form method="get">
    <div class="mb-3">
        <input type="text" name="apellido" class="form-control" placeholder="Buscar por apellido..." value="@ViewBag.Apellido" />
    </div>
    <button type="submit" class="btn btn-primary">Buscar</button>
</form>

@if (ViewBag.Error != null)
{
    <p style="color:red">@ViewBag.Error</p>
}
else
{
    <table class="table table-bordered">
        <thead>
            <tr>
                @foreach (System.Data.DataColumn column in Model.Columns)
                {
                    <th>@column.ColumnName</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (System.Data.DataRow row in Model.Rows)
            {
                <tr>
                    @foreach (var item in row.ItemArray)
                    {
                        <td>@item</td>
                    }
                </tr>
            }
        </tbody>
    </table>

    <div class="mt-3">
        <a class="btn btn-secondary @(ViewBag.CurrentPage <= 1 ? "disabled" : "")" 
           href="?page=@(ViewBag.CurrentPage - 1)&apellido=@ViewBag.Apellido">
            Anterior
        </a>

        <a class="btn btn-secondary @((ViewBag.CurrentPage * ViewBag.PageSize) >= ViewBag.TotalRecords ? "disabled" : "")" 
           href="?page=@(ViewBag.CurrentPage + 1)&apellido=@ViewBag.Apellido">
            Siguiente
        </a>
    </div>
}